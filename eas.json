{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "staging": {
      "bun": "1.3.14",
      "env": {
        "ENVIRONMENT": "staging",
        "ENTRY_FILE": "node_modules/expo/AppEntry.js"
      },
      "distribution": "internal",
      "resourceClass": "large",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
