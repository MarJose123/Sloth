{
  "expo": {
    "name": "Sloth",
    "slug": "sloth",
    "scheme": "sloth",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "@op-engineering/op-sqlite",
        {
          "sqlcipher": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B1F1A"
        }
      ]
    ],
    "android": {
      "package": "marjose.sloth.app",
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT"]
    }
  }
}
